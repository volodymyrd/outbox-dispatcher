# .env.example — copy to .env (gitignored) and fill in values before `docker compose up`.
#
# Required by docker/docker-compose.example.yml and examples/docker-compose.with-postgres.yml.

# Postgres bootstrap password (used by the postgres service on first init).
POSTGRES_PASSWORD=change-me

# Admin API bearer token — generate with: openssl rand -hex 32
ADMIN_TOKEN=change-me

# Per-signing-key HMAC secrets (one variable per [signing_keys] entry).
# The variable name must match the value configured in [signing_keys] for each key.
# Examples:
# PAYMENTS_HMAC_SECRET=change-me
# NOTIFICATIONS_HMAC_SECRET=change-me
